# Copia este archivo a .env y rellena los valores.

# --- Firebase (Configuración del proyecto → Tus apps → SDK de configuración) ---
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# --- Notificaciones push web (Firebase Cloud Messaging) ---
# Firebase Console → Configuración del proyecto → Cloud Messaging →
# "Certificados push web" → genera/copia el par de claves.
VITE_FCM_VAPID_KEY=
