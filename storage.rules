rules_version = '2';

// Reglas de Firebase Storage.
// Adjuntos de avisos (announcements/{id}/{archivo}).
//
// Nota de seguridad: NO usamos firestore.get() para verificar el rol aquí —
// esa lectura cross-service (Storage→Firestore) devolvía storage/unauthorized
// de forma intermitente y bloqueaba la subida. La protección real ya existe en
// dos capas: (1) la app solo muestra el formulario de avisos a admin/profesor;
// (2) el documento del aviso en Firestore solo lo pueden crear admin/profesor
// (firestore.rules). Un usuario sin permiso podría subir un archivo suelto pero
// no puede convertirlo en un aviso visible. Limitamos por autenticación y tamaño.
service firebase.storage {
  match /b/{bucket}/o {

    // Adjuntos de avisos.
    match /announcements/{announcementId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.resource.size < 20 * 1024 * 1024;
      allow delete: if request.auth != null;
    }

    // Adjuntos de eventos del calendario (misma política que avisos).
    match /events/{eventId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.resource.size < 20 * 1024 * 1024;
      allow delete: if request.auth != null;
    }

    // Adjuntos y portadas de talleres.
    match /workshops/{workshopId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.resource.size < 20 * 1024 * 1024;
      allow delete: if request.auth != null;
    }

    // Todo lo demás queda bloqueado por defecto.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
